# Copy to .env (same directory) and fill in:
#   cp .env.example .env && nano .env

# The domain that points at this server (A record -> server IP).
# Baked into the Android APK — changing it later requires a new APK.
DOMAIN=nav.velogearpremium.com

# Server-held Anthropic API key (users of the app won't need their own).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Model used for the background store scans (needs web-tool support).
SCAN_MODEL=claude-sonnet-5

# --- Optional tuning (safe to leave commented; these are the defaults) ---
# How often stores are rescanned in the background, in ms (default 10 min).
# SCAN_INTERVAL_MS=600000
# Per-IP /api/message requests per minute.
# RATE_PER_MIN=30
# Per-IP store-scan requests per minute.
# SCAN_RATE_PER_MIN=6
# Global requests per minute across all IPs.
# GLOBAL_RATE_PER_MIN=300
# Trusted reverse-proxy hops in front of the app (Caddy = 1). Set 0 if you expose
# the app directly with no proxy, so client X-Forwarded-For is ignored.
# TRUST_PROXY=1
