{
  "name": "@fuzefront/chat-service",
  "version": "1.0.0",
  "description": "AI chat microservice for FuzeFront — RAG, agent loop, streaming",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "jest",
    "migrate": "knex --knexfile src/db/knexfile.ts migrate:latest",
    "migrate:make": "knex --knexfile src/db/knexfile.ts migrate:make",
    "index:docs": "echo 'indexer added in a later unit'"
  },
  "dependencies": {
    "@fuzefront/shared": "file:../../shared",
    "express": "4.19.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "2.2.4",
    "knex": "^3.1.0",
    "pg": "^8.11.5",
    "zod": "3.22.4",
    "express-rate-limit": "^7.2.0",
    "rate-limit-redis": "^4.2.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "18.19.0",
    "@types/supertest": "6.0.2",
    "jest": "29.7.0",
    "nodemon": "3.0.1",
    "supertest": "6.3.3",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.2",
    "typescript": "5.1.6"
  }
}
