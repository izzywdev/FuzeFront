{
  "name": "@fuzefront/app-registry-client",
  "version": "1.0.0",
  "description": "Typed HTTP client + manifest types for the FuzeFront app-registry API",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "gen:types": "openapi-typescript ../services/app-registry-service/openapi.yaml -o src/schema.ts",
    "lint:contract": "spectral lint ../services/app-registry-service/openapi.yaml --ruleset ../services/app-registry-service/.spectral.yaml",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izzywdev/FuzeFront.git",
    "directory": "apps-client"
  },
  "author": "FuzeFront Team",
  "license": "UNLICENSED",
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.11.0",
    "@types/node": "18.19.0",
    "openapi-typescript": "^7.4.0",
    "rimraf": "^5.0.1",
    "tsup": "^8.0.2",
    "typescript": "5.1.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}
