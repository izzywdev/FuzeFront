{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@fuzefront/identity-ui": ["../packages/identity-ui/dist/index.d.ts"],
      "@fuzefront/account-security-ui": ["../packages/account-security-ui/src/index.ts"],
      "@fuzefront/i18n": ["../packages/i18n/dist/index.d.ts"],
      "@fuzefront/chat-ui": ["../packages/chat-ui/dist/index.d.ts"],
      "@fuzefront/chat-client": ["../packages/chat-client/dist/index.d.ts"],
      "@fuzefront/billing-ui": ["../packages/billing-ui/src/index.ts"],
      "@fuzefront/billing-client": ["../billing-client/src/index.ts"],
      "@fuzefront/app-registry-client": ["../apps-client/src/index.ts"],
      "@fuzefront/security-client": ["../packages/security/src/index.ts"],
      "@fuzefront/design-system": ["../design-system/index.d.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
