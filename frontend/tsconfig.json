{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@fuzefront/i18n": ["../packages/i18n/src/index.ts"],
      // The i18n source imports the design-system <Select>; resolve it (and its
      // transitive "react" types, which live outside ./frontend) so the host
      // type-check covers the wiring. Real installs resolve these as deps.
      "@fuzefront/design-system": ["../design-system/index.d.ts"],
      // The @fuzefront/i18n + design-system source live outside ./frontend and
      // resolve their runtime/type deps relative to their own location (which
      // has no node_modules in this tree). Map those deps to the host's
      // installed copies so the host type-check resolves the wiring. Real
      // installs resolve them as the packages' own deps.
      "react": ["./node_modules/@types/react"],
      "react-dom": ["./node_modules/@types/react-dom"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime"],
      "i18next": ["./node_modules/i18next"],
      "react-i18next": ["./node_modules/react-i18next"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
