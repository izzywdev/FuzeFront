{
  "name": "@fuzefront/frontend",
  "private": true,
  "version": "1.0.0",
  "description": "FuzeFront container shell application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "build:check": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "test": "vitest run --config vitest.config.ts",
    "test:ui": "vitest --ui --config vitest.config.ts",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@fuzefront/chat-client": "file:../packages/chat-client",
    "@fuzefront/chat-ui": "file:../packages/chat-ui",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "axios": "^1.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^23.11.5",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.2",
    "react-router": "^7.6.2",
    "react-router-dom": "^7.6.2",
    "socket.io-client": "^4.7.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@playwright/test": "^1.53.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@tanstack/react-table": "^8.21.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.20",
    "eventsource-parser": "^1.1.2",
    "jsdom": "^22.1.0",
    "papaparse": "^5.5.4",
    "postcss": "^8.5.6",
    "react-hook-form": "^7.80.0",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.4",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.0"
  }
}
