{
  "name": "@fuzefront/shared",
  "version": "1.0.0",
  "description": "Shared state library for FuzeFront platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./kafka": {
      "types": "./dist/kafka/index.d.ts",
      "default": "./dist/kafka/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:kafka": "tsc -p tsconfig.kafka.json",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "kafkajs": "2.2.4",
    "react": "^18.2.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/react": "^18.2.15",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  }
}
