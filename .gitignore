node_modules/

# SSH Keys and sensitive files
keys/
*.pem
*.key

# Environment files — never commit real secrets. Use the .env.example templates.
.env
**/.env
!.env.example
!**/.env.example

# Playwright artifacts
**/test-results/
**/playwright-report/
frontend/screens/

# Downloaded CLI tools / binaries (never commit — re-downloadable)
/cloudflared
/cloudflared.deb
/mkcert
*.deb

# Local agent tooling / throwaway captures
AGENTS.md
frontend/tests/_screens.spec.ts

# Local dev CA public cert (per-machine; regenerate via deploy/local-tls/)
deploy/local-tls/*.crt

# Isolated per-worktree npm caches (parallel-agent gotcha)
.npm-cache-*/

# Build output for the @fuzefront/* npm packages (regenerated by `npm run build`)
packages/*/dist/

# Per-package local .npmrc workarounds (Windows native-binary installs only;
# the repo's os=linux pin must NOT be overridden in CI).
packages/*/.npmrc

# Stray npm pack tarballs
*.tgz

# Per-package lockfiles (generated locally; CI installs fresh).
packages/*/package-lock.json

# Android TWA keystore binary — store as base64 in ANDROID_KEYSTORE_B64 GitHub Secret
android/keystore/*.keystore
android/keystore/*.jks
# Bubblewrap-generated Android project (reproducible via `bubblewrap init`)
android/app/
android/gradle/
android/gradlew
android/gradlew.bat
android/build.gradle
android/settings.gradle
android/local.properties

# Vite build output (generated; not committed)
frontend/dist/

