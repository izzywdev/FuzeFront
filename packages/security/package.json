{
  "name": "@fuzefront/security-client",
  "version": "0.1.0",
  "description": "Provider-agnostic client + types for the FuzeFront Security API (AuthN + AuthZ). Generated from openapi.yaml; consumers know only FuzeFront, never a vendor.",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izzywdev/FuzeFront.git",
    "directory": "packages/security"
  },
  "files": [
    "dist",
    "openapi.yaml",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "generate": "openapi-typescript openapi.yaml -o src/generated.ts",
    "lint:spec": "spectral lint openapi.yaml",
    "prebuild": "npm run generate",
    "build": "tsup",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "18.19.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.0.2",
    "typescript": "5.1.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}
