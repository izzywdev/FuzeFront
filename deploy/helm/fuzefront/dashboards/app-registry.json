{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "FuzeFront — App Registry",
  "tags": ["fuzefront", "app-registry"],
  "timezone": "",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "app-registry write rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(app_registry_write_requests_total{namespace=\"fuzefront\"}[5m]))",
          "legendFormat": "writes"
        }
      ]
    },
    {
      "id": 2,
      "title": "app-registry write error rate (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "targets": [
        {
          "expr": "100 * sum(rate(app_registry_write_errors_total{namespace=\"fuzefront\"}[5m])) / clamp_min(sum(rate(app_registry_write_requests_total{namespace=\"fuzefront\"}[5m])), 1)",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "app.* event emission (rate/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(app_registry_events_emitted_total{namespace=\"fuzefront\"}[5m]))",
          "legendFormat": "emitted"
        },
        {
          "expr": "sum(rate(app_registry_event_emit_failed_total{namespace=\"fuzefront\"}[5m]))",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "id": 4,
      "title": "applications-service request latency p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"fuzefront-applications\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "clock-app remote up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(up{service=\"clock-app\",namespace=\"fuzefront\"})",
          "legendFormat": "up replicas"
        }
      ]
    },
    {
      "id": 6,
      "title": "applications-service pod restarts (1h increase)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=\"fuzefront\",pod=~\"fuzefront-applications.*|clock-app.*\"}[1h]))",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
